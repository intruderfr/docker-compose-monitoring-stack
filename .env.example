# Copy this file to `.env` and edit as needed.
#
#   cp .env.example .env
#
# Values here are read by docker-compose.yml via `${VAR:-default}` syntax.

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
GRAFANA_PORT=3000
GRAFANA_ROOT_URL=http://localhost:3000

# --- Prometheus ---
PROMETHEUS_PORT=9090
PROMETHEUS_EXTERNAL_URL=http://localhost:9090
# Retention for the local TSDB. Keep an eye on disk use if you increase this.
PROMETHEUS_RETENTION=15d

# --- Alertmanager ---
ALERTMANAGER_PORT=9093
ALERTMANAGER_EXTERNAL_URL=http://localhost:9093

# --- Optional notification channels ---
# Fill these in AND uncomment the matching receiver block in
# alertmanager/alertmanager.yml before restarting alertmanager.
# SLACK_WEBHOOK_URL=
# SMTP_PASSWORD=
